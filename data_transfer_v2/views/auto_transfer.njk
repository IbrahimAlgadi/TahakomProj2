{% extends './layout/layout.njk' %}

{% block content %}

    <div class="container-fluid">

        <!-- Header Section -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Automatic USB Transfer</h1>
        </div>

        <!-- Drive Configuration Card -->
        <div class="row mb-4">

            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="card">
                    <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-hdd me-2"></i>Drive Configuration
                        </h5>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="transferActiveToggle">
                            <label class="form-check-label" for="transferActiveToggle">Transfer Toggle Active</label>
                        </div>
                    </div>
                    <div class="card-body">
                        <form id="autoTransferForm" onsubmit="return false;">
                            <!-- Transfer Mode Selection -->
                            <div class="form-group mb-4">
                                <label class="form-label">Transfer Device</label>
                                
                                <div class="form-check mb-2">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="transferMode" 
                                        id="specificUSB"
                                        value="specific"
                                        checked
                                    >
                                    <label class="form-check-label" for="specificUSB">
                                        <strong>Connected USB</strong> - Transfer to specific USB drive
                                    </label>
                                </div>

                                <div class="form-check mb-3">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="transferMode"
                                        id="anyUSB"
                                        value="any"
                                    >
                                    <label class="form-check-label" for="anyUSB">
                                        <strong>Transfer to any connected USB</strong> - Automatically transfer to any USB that gets connected
                                    </label>
                                </div>
                            </div>

                            <!-- USB Drive Selection (for specific USB mode) -->
                            <div class="form-group mb-4" id="driveSelectionSection">
                                <label class="form-label">Connected USB Drive</label>
                                <div class="input-group">
                                    <select class="form-select" id="driveSelect">
                                        <option value="">Loading connected drives...</option>
                                    </select>
                                    <button class="btn btn-outline-secondary" type="button" id="refreshDrives" title="Refresh drive list">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                </div>
                                <div class="form-text">Select the specific USB drive for transfer operations</div>
                                <div id="driveSelectionMessage" class="mt-2"></div>
                            </div>

                            <!-- Transfer Schedule Selection -->
                            <div class="form-group mb-4">
                                <label class="form-label">Transfer Schedule</label>
                                
                                <div class="form-check mb-2">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="transferSchedule" 
                                        id="continuousTransfer"
                                        value="continuous"
                                        checked
                                    >
                                    <label class="form-check-label" for="continuousTransfer">
                                        <i class="fas fa-infinity me-2 text-primary"></i><strong>Continuous Loop</strong> - Transfer files immediately when USB is connected
                                    </label>
                                </div>

                                <div class="form-check mb-3">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="transferSchedule"
                                        id="scheduledTransfer"
                                        value="scheduled"
                                    >
                                    <label class="form-check-label" for="scheduledTransfer">
                                        <i class="fas fa-clock me-2 text-info"></i><strong>Scheduled Transfer</strong> - Transfer files at specific times
                                    </label>
                                </div>
                            </div>

                            <!-- Scheduled Transfer Options (hidden by default) -->
                            <div class="form-group mb-4" id="scheduleOptionsSection" style="display: none;">
                                <div class="card">
                                    <div class="card-body">
                                        <h6 class="card-title mb-3">Schedule Configuration</h6>
                                        
                                        <div class="form-group mb-3">
                                            <label class="form-label">Schedule Type</label>
                                            
                                            <div class="form-check mb-2">
                                                <input 
                                                    class="form-check-input" 
                                                    type="radio" 
                                                    name="scheduleType" 
                                                    id="hourlySchedule"
                                                    value="hourly"
                                                    checked
                                                >
                                                <label class="form-check-label" for="hourlySchedule">
                                                    <i class="fas fa-hourglass-half me-2"></i><strong>Hourly</strong> - Transfer at specific hour each day
                                                </label>
                                            </div>

                                            <div class="form-check mb-3">
                                                <input 
                                                    class="form-check-input" 
                                                    type="radio" 
                                                    name="scheduleType"
                                                    id="weeklySchedule"
                                                    value="weekly"
                                                >
                                                <label class="form-check-label" for="weeklySchedule">
                                                    <i class="fas fa-calendar-week me-2"></i><strong>Weekly</strong> - Transfer on specific day of the week
                                                </label>
                                            </div>
                                        </div>

                                        <!-- Hourly Schedule Options -->
                                        <div class="form-group mb-3" id="hourlyOptions">
                                            <label class="form-label">Select Hour</label>
                                            <select class="form-select" id="scheduleHour">
                                                <option value="0">12:00 AM (Midnight)</option>
                                                <option value="1">1:00 AM</option>
                                                <option value="2">2:00 AM</option>
                                                <option value="3">3:00 AM</option>
                                                <option value="4">4:00 AM</option>
                                                <option value="5">5:00 AM</option>
                                                <option value="6">6:00 AM</option>
                                                <option value="7">7:00 AM</option>
                                                <option value="8">8:00 AM</option>
                                                <option value="9" selected>9:00 AM</option>
                                                <option value="10">10:00 AM</option>
                                                <option value="11">11:00 AM</option>
                                                <option value="12">12:00 PM (Noon)</option>
                                                <option value="13">1:00 PM</option>
                                                <option value="14">2:00 PM</option>
                                                <option value="15">3:00 PM</option>
                                                <option value="16">4:00 PM</option>
                                                <option value="17">5:00 PM</option>
                                                <option value="18">6:00 PM</option>
                                                <option value="19">7:00 PM</option>
                                                <option value="20">8:00 PM</option>
                                                <option value="21">9:00 PM</option>
                                                <option value="22">10:00 PM</option>
                                                <option value="23">11:00 PM</option>
                                            </select>
                                            <div class="form-text">Transfer will occur daily at the selected hour</div>
                                        </div>

                                        <!-- Weekly Schedule Options -->
                                        <div class="form-group mb-3" id="weeklyOptions" style="display: none;">
                                            <label class="form-label">Select Day of Week</label>
                                            <select class="form-select" id="scheduleDayOfWeek">
                                                <option value="0">Sunday</option>
                                                <option value="1" selected>Monday</option>
                                                <option value="2">Tuesday</option>
                                                <option value="3">Wednesday</option>
                                                <option value="4">Thursday</option>
                                                <option value="5">Friday</option>
                                                <option value="6">Saturday</option>
                                            </select>
                                            <div class="form-text">Transfer will occur weekly on the selected day</div>
                                            
                                            <label class="form-label mt-3">Select Time</label>
                                            <select class="form-select" id="scheduleWeeklyHour">
                                                <option value="0">12:00 AM (Midnight)</option>
                                                <option value="1">1:00 AM</option>
                                                <option value="2">2:00 AM</option>
                                                <option value="3">3:00 AM</option>
                                                <option value="4">4:00 AM</option>
                                                <option value="5">5:00 AM</option>
                                                <option value="6">6:00 AM</option>
                                                <option value="7">7:00 AM</option>
                                                <option value="8">8:00 AM</option>
                                                <option value="9" selected>9:00 AM</option>
                                                <option value="10">10:00 AM</option>
                                                <option value="11">11:00 AM</option>
                                                <option value="12">12:00 PM (Noon)</option>
                                                <option value="13">1:00 PM</option>
                                                <option value="14">2:00 PM</option>
                                                <option value="15">3:00 PM</option>
                                                <option value="16">4:00 PM</option>
                                                <option value="17">5:00 PM</option>
                                                <option value="18">6:00 PM</option>
                                                <option value="19">7:00 PM</option>
                                                <option value="20">8:00 PM</option>
                                                <option value="21">9:00 PM</option>
                                                <option value="22">10:00 PM</option>
                                                <option value="23">11:00 PM</option>
                                            </select>
                                        </div>

                                        <div class="alert alert-info">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <strong>Note:</strong> Scheduled transfers will only execute if the USB drive is connected at the scheduled time.
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Data Type Selection -->
                            <div class="form-group mb-4">
                                <label class="form-label">Data to Transfer</label>
                                
                                <div class="form-check mb-2">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="dataType" 
                                        id="imagesOnly"
                                        value="images"
                                    >
                                    <label class="form-check-label" for="imagesOnly">
                                        <i class="fas fa-image me-2 text-primary"></i><strong>Images Only</strong> - Transfer image files (.jpg, .jpeg)
                                    </label>
                                </div>

                                <div class="form-check mb-2">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="dataType"
                                        id="videosOnly"
                                        value="videos"
                                    >
                                    <label class="form-check-label" for="videosOnly">
                                        <i class="fas fa-video me-2 text-success"></i><strong>Videos Only</strong> - Transfer video files (.mp4)
                                    </label>
                                </div>

                                <div class="form-check mb-3">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="dataType"
                                        id="bothTypes"
                                        value="both"
                                        checked
                                    >
                                    <label class="form-check-label" for="bothTypes">
                                        <i class="fas fa-file-alt me-2 text-info"></i><strong>Both Images & Videos</strong> - Transfer all media files
                                    </label>
                                </div>
                            </div>

                            <!-- Encryption Settings -->
                            <div class="mb-4">
                                <label class="form-label">File Encryption</label>

                                <div class="form-check mb-2">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="encryptionType" 
                                        id="noEncryption"
                                        checked
                                    >
                                    <label class="form-check-label" for="noEncryption">
                                        Disable encryption
                                    </label>
                                </div>

                                <div class="form-check mb-3">
                                    <input 
                                        class="form-check-input" 
                                        type="radio" 
                                        name="encryptionType"
                                        id="useEncryption"
                                    >
                                    <label class="form-check-label" for="useEncryption">
                                        Enable encryption
                                    </label>
                                </div>

                                <div class="alert alert-info" id="encryptionInfo">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Encryption Settings:</strong> Centrally managed from <a href="/" class="alert-link">All Files page</a>. 
                                    Current settings will be applied automatically when encryption is enabled.
                                </div>
                            </div>

                            <!-- Drive Info Display -->
                            <div id="driveInfo" class="mb-4 d-none">
                                <h6 class="mb-3">Drive Information</h6>
                                <div class="progress mb-2">
                                    <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                </div>
                                <div class="small text-muted">
                                    <span id="usedSpace">0 GB</span> used of <span id="totalSpace">0 GB</span>
                                </div>
                            </div>

                            <div class="button-group">
                                <button type="button" class="btn btn-outline-primary" id="testConnection">
                                    <i class="fas fa-plug me-2"></i>
                                    Test Connection
                                </button>
                                <button type="button" class="btn btn-primary" id="saveConfig" disabled>
                                    <i class="fas fa-save me-2"></i>
                                    Save Configuration
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">

                <div class="card">
                    <div class="card-header bg-transparent border-0">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-chart-pie me-2"></i>
                            Drive Status
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted">Storage Usage</span>
                                <span class="fw-medium">
                                    <span class="driveSpaceUsed">-</span> / <span class="driveTotalSpace">-</span></span>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" id="driveUsedSpacePercentage" style="width: 0%"></div>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <div class="p-3 bg-light rounded">
                                    <div class="text-muted small">Available Space</div>
                                    <div class="fw-bold">
                                        <span class="driveRemainSpace">-</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-light rounded">
                                    <div class="text-muted small">Used Space</div>
                                    <div class="fw-bold">
                                        <span class="driveSpaceUsed">-</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!--
                        <button class="btn btn-primary w-100">
                            <i class="fas fa-play me-2"></i>
                            Start Transfer
                        </button>
                        -->
                    </div>
                </div>

                <!-- Transfer Status Card -->
                <div class="card mt-3">

                    <div class="card-header bg-transparent border-0">
                        <h5 class="card-title mb-0">
                            <i class="fas fa-exchange-alt me-2"></i>
                            Transfer Status
                        </h5>
                    </div>

                    <div class="card-body">
                        <div id="transferStatusDiv" class="p-3 bg-secondary bg-opacity-10 rounded mb-3 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <span id="driveStatusIcon">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                </span>
                                Drive
                            </div>
                            <span id="connectedDriveStatusText" class="badge bg-secondary">Waiting</span>
                        </div>

                        <!-- Cursor State Panel (time-cursor transfer tracking) -->
                        <div class="p-3 bg-light rounded mb-3">
                            <h6 class="mb-2">
                                <i class="fas fa-history me-2 text-info"></i>
                                Transfer Cursor State
                            </h6>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted small"><i class="fas fa-image me-1"></i> Image Cursor</span>
                                <span class="badge bg-primary text-white" id="cursorLastImageTransferredAt">Never</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted small"><i class="fas fa-video me-1"></i> Video Cursor</span>
                                <span class="badge bg-info text-white" id="cursorLastVideoTransferredAt">Never</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small"><i class="fas fa-plug me-1"></i> Last USB Connected</span>
                                <span class="badge bg-secondary text-white" id="cursorLastConnectedAt">Never</span>
                            </div>
                        </div>

                        <div class="p-3 bg-light rounded mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="text-muted">Current Transfer</div>
                                <span id="currentTransferStatus" class="badge bg-secondary">idle</span>
                            </div>
                            <div class="text-truncate">
                                <i class="fas fa-file me-2"></i>
                                <span id="statusMessages">-</span>
                            </div>
                        </div>

                        <!-- Transfer Progress Card -->
                        <div class="row mb-4" id="transferProgressSection">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-header bg-transparent border-0">
                                        <h5 class="card-title mb-0">
                                            <i class="fas fa-chart-line me-2"></i>
                                            Real-time Transfer Progress
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <!-- Current Job Info -->
                                        <div class="mb-3" id="currentJobInfo">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="text-muted">Current Job</span>
                                                <span class="badge bg-info" id="currentJobId">-</span>
                                            </div>
                                        </div>
                                        
                                        <!-- Image Transfer Progress -->
                                        <div class="mb-4" id="imageTransferProgress" >
                                            <h6 class="mb-3">
                                                <i class="fas fa-image me-2 text-primary"></i>
                                                Image Transfer Progress
                                            </h6>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="fw-medium">Files Processed</span>
                                                <span class="text-muted">
                                                    <span id="imageProcessedCount">0</span> / <span id="imageTotalCount">0</span>
                                                    (<span id="imageProgressPercentage">0</span>%)
                                                </span>
                                            </div>
                                            <div class="progress mb-2" style="height: 8px;">
                                                <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" id="imageProgressBar" style="width: 0%"></div>
                                            </div>
                                            <div class="row g-2 mb-2">
                                                <div class="col-md-8">
                                                    <div class="small text-muted">
                                                        <i class="fas fa-file me-1"></i>
                                                        <span id="imageCurrentFile">Ready...</span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4">
                                                    <div class="small text-muted text-md-end">
                                                        <i class="fas fa-exclamation-triangle me-1 text-warning" id="imageFailedIcon" style="display: none;"></i>
                                                        Failed: <span id="imageFailedCount">0</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="row g-2 text-center" id="imagePerformanceStats" style="display: none;">
                                                <div class="col-4">
                                                    <div class="p-2 bg-light rounded">
                                                        <div class="text-muted small">Throughput</div>
                                                        <div class="fw-bold small" id="imageThroughputValue">-</div>
                                                    </div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="p-2 bg-light rounded">
                                                        <div class="text-muted small">Duration</div>
                                                        <div class="fw-bold small" id="imageBatchDuration">-</div>
                                                    </div>
                                                </div>
                                                <div class="col-4">
                                                    <div class="p-2 bg-light rounded">
                                                        <div class="text-muted small">Success Rate</div>
                                                        <div class="fw-bold small" id="imageSuccessRate">-</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <!-- Video Transfer Progress -->
                                        <div class="mb-4" id="videoTransferProgress" >
                                            <h6 class="mb-3">
                                                <i class="fas fa-video me-2 text-success"></i>
                                                Video Transfer Progress
                                            </h6>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="fw-medium">Camera Processing</span>
                                                <span class="text-muted" id="videoCameraStatus">Ready...</span>
                                            </div>
                                            <div class="progress mb-2" style="height: 8px;">
                                                <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" id="videoProgressBar" style="width: 0%"></div>
                                            </div>
                                            <div class="small text-muted mb-3">
                                                <i class="fas fa-video me-1"></i>
                                                <span id="videoCurrentFile">Ready...</span>
                                            </div>
                                            <div class="row g-2" id="videoCameraGrid">
                                                <!-- Camera progress will be populated here -->
                                            </div>
                                        </div>
                                        
                                        <!-- Overall Progress Summary -->
                                        <div class="alert alert-secondary mb-0" id="transferSummary">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <span id="transferSummaryText">No active transfers - system ready</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i>
                                Transfer will stop at 100% capacity
                            </div>
                    </div>

                </div>

            </div>

        </div>

        

    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        <div id="notificationToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <i class="fas fa-info-circle me-2"></i>
                <strong class="me-auto" id="toastTitle">Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastMessage"></div>
        </div>
    </div>

{% endblock %}

{% block script %}
    <script>
        $('.auto-transfer').addClass('active');
    </script>

    <script>
        const AUTO_TRANSFER_SERVICE_URL = 'http://localhost:8454';
        const AUTO_TRANSFER_WS_URL = 'ws://localhost:8454';
        let isDriveConnected = false;
        let isSaveConfigDriveTested = false;
        let connectedDevices = [];
        let savedConfig = null;
        let configLoaded = false;
        let devicesLoaded = false;

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB', 'PB'];
            const i = Math.floor(Math.log(bytes) / Math.log(1024));
            const value = (bytes / Math.pow(1024, i)).toFixed(2);
            return `${value} ${sizes[i]}`;
        }

        function formatTimestamp(isoStr) {
            if (!isoStr) return 'Never';
            try {
                return new Date(isoStr).toLocaleString();
            } catch (e) {
                return isoStr;
            }
        }

        function updateCursorDisplay(cfg) {
            const imgEl = document.getElementById('cursorLastImageTransferredAt');
            const vidEl = document.getElementById('cursorLastVideoTransferredAt');
            const lcaEl = document.getElementById('cursorLastConnectedAt');
            // Support both old single-cursor config and new split-cursor config
            const imgTs = cfg.lastImageTransferredAt || cfg.lastTransferredAt;
            const vidTs = cfg.lastVideoTransferredAt || cfg.lastTransferredAt;
            const lcaTs = cfg.lastConnectedAt;
            if (imgEl) {
                imgEl.textContent = formatTimestamp(imgTs);
                imgEl.className = imgTs ? 'badge bg-primary text-white' : 'badge bg-secondary text-white';
            }
            if (vidEl) {
                vidEl.textContent = formatTimestamp(vidTs);
                vidEl.className = vidTs ? 'badge bg-info text-white' : 'badge bg-secondary text-white';
            }
            if (lcaEl) {
                lcaEl.textContent = formatTimestamp(lcaTs);
                lcaEl.className = lcaTs ? 'badge bg-success text-white' : 'badge bg-secondary text-white';
            }
        }

        // Toast notification function
        function showToast(message, type = 'info') {
            const toast = document.getElementById('notificationToast');
            const toastTitle = document.getElementById('toastTitle');
            const toastBody = document.getElementById('toastBody');

            // Set toast type
            toast.className = `toast align-items-center text-white bg-${type} border-0`;
            
            // Set toast content
            toastTitle.textContent = type.charAt(0).toUpperCase() + type.slice(1);
            toastBody.textContent = message;

            // Show toast
            const bsToast = new bootstrap.Toast(toast);
            bsToast.show();
        }

        function toggleFormControls(isTransferActive) {
            const form = document.getElementById('autoTransferForm');
            const formElements = form.querySelectorAll('input:not(#transferActiveToggle), select');
            
            // When transfer is active, disable form. When inactive, enable form
            formElements.forEach(element => {
                element.disabled = isTransferActive;
            });

            // Special handling for save and test buttons
            const saveButton = document.getElementById('saveConfig');
            const testButton = document.getElementById('testConnection');
            
            if (isTransferActive) {
                // When transfer is active, disable both buttons
                testButton.disabled = true;
                saveButton.disabled = true;
            } else {
                // When transfer is inactive, enable test button
                testButton.disabled = false;
                // Enable save button only if drive is tested or in 'any USB' mode
                const transferMode = $('input[name="transferMode"]:checked').val();
                saveButton.disabled = !(transferMode === 'any' || isSaveConfigDriveTested);
            }
        }

        function updateDriveStatus(status) {
            const statusDiv = document.getElementById('transferStatusDiv');
            const statusIcon = document.getElementById('driveStatusIcon');
            const statusText = document.getElementById('connectedDriveStatusText');
            const saveButton = document.getElementById('saveConfig');

            statusDiv.classList.remove('bg-success', 'bg-danger', 'bg-secondary');
            statusText.classList.remove('bg-success', 'bg-danger', 'bg-secondary');

            if (status === 'DRIVE_NOT_CONNECTED') {
                isDriveConnected = false;
                statusDiv.classList.add('bg-danger');
                statusText.classList.add('bg-danger');
                statusText.textContent = 'disconnected';
                statusIcon.innerHTML = '<i class="fas fa-times-circle text-danger me-2"></i>';
                // saveButton.disabled = true;
            } else if (status === 'TRANSFER_STOPPED') {
                isDriveConnected = false;
                statusDiv.classList.add('bg-secondary');
                statusText.classList.add('bg-secondary');
                statusText.textContent = 'stopped';
                statusIcon.innerHTML = '<i class="fas fa-stop-circle text-secondary me-2"></i>';
                // saveButton.disabled = true;
            } else {
                isDriveConnected = true;
                isSaveConfigDriveTested = true;
                statusDiv.classList.add('bg-success');
                statusText.classList.add('bg-success');
                statusText.textContent = 'connected';
                statusIcon.innerHTML = '<i class="fas fa-check-circle text-success me-2"></i>';
                saveButton.disabled = false;  
            }
        }

        function updateTransferStatus(status) {
            const statusBadge = document.getElementById('currentTransferStatus');
            const statusMessage = document.getElementById('statusMessages');
            const saveButton = document.getElementById('saveConfig');
            
            statusBadge.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'bg-secondary');
            
            switch(status.return_event) {
                case 'COPY_SUCCESS':
                    statusBadge.classList.add('bg-success');
                    statusBadge.textContent = 'Success';
                    saveButton.disabled = true;
                    break;
                case 'COPY_ERROR':
                    statusBadge.classList.add('bg-danger');
                    statusBadge.textContent = 'Error';
                    break;
                case 'COPY_PAUSE':
                    statusBadge.classList.add('bg-warning');
                    statusBadge.textContent = 'Paused';
                    break;
                case 'DRIVE_NOT_CONNECTED':
                    statusBadge.classList.add('bg-danger');
                    statusBadge.textContent = 'Drive Error';
                    break;
                case 'TRANSFER_STOPPED':
                    statusBadge.classList.add('bg-secondary');
                    statusBadge.textContent = 'Stopped';
                    break;
                default:
                    statusBadge.classList.add('bg-secondary');
                    statusBadge.textContent = 'Idle';
            }

            if (status.msg) {
                statusMessage.textContent = status.msg.slice(0, 100);
            }
        }

        function updateDriveInfo(driveInfo) {
            if (!driveInfo) return;

            const totalSpace = driveInfo.totalSpace;
            const usedSpace = driveInfo.usedSpace;
            const remainingSpace = driveInfo.remainingSpace;
            const usedPercentage = (usedSpace / totalSpace * 100).toFixed(2);

            $('.driveTotalSpace').html(formatFileSize(totalSpace));
            $('.driveSpaceUsed').html(formatFileSize(usedSpace));
            $('.driveRemainSpace').html(formatFileSize(remainingSpace));
            document.getElementById('driveUsedSpacePercentage').style.width = usedPercentage + '%';
        }

        function updateConnectedDrives(devices) {
            connectedDevices = devices || [];
            const driveSelect = document.getElementById('driveSelect');
            const driveMessage = document.getElementById('driveSelectionMessage');
            const currentValue = driveSelect.value;
            
            // Clear existing options
            driveSelect.innerHTML = '';
            
            if (connectedDevices.length === 0) {
                driveSelect.innerHTML = '<option value="">No USB drives connected</option>';
                driveSelect.disabled = true;
                driveMessage.innerHTML = '<div class="alert alert-warning mb-0"><i class="fas fa-exclamation-triangle me-2"></i>No external USB drives are currently connected. Please connect a USB drive to continue.</div>';
            } else {
                driveSelect.disabled = false;
                driveMessage.innerHTML = '';
                
                // Add default option
                driveSelect.innerHTML = '<option value="">Select a USB drive</option>';
                
                // Add connected drives
                connectedDevices.forEach(device => {
                    const option = document.createElement('option');
                    option.value = device.drive.replace(':', ''); // Remove colon from drive letter
                    // Convert space values from GB strings to bytes for formatFileSize
                    const remainingSpaceBytes = parseFloat(device.remainingspace) * 1024 * 1024 * 1024;
                    option.textContent = `Drive ${device.drive} (${device.label || 'Unnamed'}) - ${formatFileSize(remainingSpaceBytes)} free`;
                    driveSelect.appendChild(option);
                });
                
                // Add change event listener to drive selection
                driveSelect.onchange = function() {
                    if (savedConfig) {
                        savedConfig.drive = this.value;
                        evaluateDriveStatus();
                    }
                };
                
                // Restore previous selection if still available
                let selectionRestored = false;
                if (currentValue && Array.from(driveSelect.options).some(opt => opt.value === currentValue)) {
                    driveSelect.value = currentValue;
                    selectionRestored = true;
                } else if (savedConfig && savedConfig.drive && savedConfig.drive !== 'ANY' && Array.from(driveSelect.options).some(opt => opt.value === savedConfig.drive)) {
                    // Restore saved configuration drive if available
                    driveSelect.value = savedConfig.drive;
                    selectionRestored = true;
                }
                
                let successMessage = `<div class="alert alert-success mb-0"><i class="fas fa-check-circle me-2"></i>Found ${connectedDevices.length} connected USB drive(s)`;
                if (selectionRestored && driveSelect.value) {
                    const selectedOption = Array.from(driveSelect.options).find(opt => opt.value === driveSelect.value);
                    if (selectedOption) {
                        successMessage += ` (Selected: ${selectedOption.textContent})`;
                    }
                } else if (savedConfig && savedConfig.drive && savedConfig.drive !== 'ANY' && !Array.from(driveSelect.options).some(opt => opt.value === savedConfig.drive)) {
                    // Saved drive is not available
                    successMessage += ` - <span class="text-warning">Previously selected drive "${savedConfig.drive}" is not connected</span>`;
                }
                successMessage += '</div>';
                driveMessage.innerHTML = successMessage;
            }
        }

        function evaluateDriveStatus() {
            if (!configLoaded || !devicesLoaded) return;
            
            const transferMode = (savedConfig && savedConfig.transferMode) || 'specific';
            const configuredDrive = savedConfig && savedConfig.drive;
            
            console.log('🔍 Evaluating drive status:', { transferMode, configuredDrive, connectedDevices: connectedDevices.length });
            
            if (transferMode === 'any' || configuredDrive === 'ANY') {
                // For "any USB" mode, check if any drives are connected
                if (connectedDevices.length > 0) {
                    updateDriveStatus('CONNECTED');
                    updateTransferStatus({
                        return_event: 'COPY_SUCCESS',
                        msg: `Ready for auto-transfer (${connectedDevices.length} drive(s) available)`
                    });
                } else {
                    updateDriveStatus('DRIVE_NOT_CONNECTED');
                    updateTransferStatus({
                        return_event: 'DRIVE_NOT_CONNECTED',
                        msg: 'No USB drives connected'
                    });
                }
            } else if (configuredDrive) {
                // For specific USB mode, check if the configured drive is connected
                const isDriveConnected = connectedDevices.some(device => 
                    device.drive.replace(':', '') === configuredDrive
                );
                
                if (isDriveConnected) {
                    const connectedDevice = connectedDevices.find(device => 
                        device.drive.replace(':', '') === configuredDrive
                    );
                    updateDriveStatus('CONNECTED');
                    updateTransferStatus({
                        return_event: 'COPY_SUCCESS',
                        msg: `Drive ${configuredDrive}: ready for auto-transfer`
                    });
                    if (connectedDevice) {
                        updateDriveInfo({
                            totalSpace: parseFloat(connectedDevice.totalspace) * 1024 * 1024 * 1024,
                            usedSpace: parseFloat(connectedDevice.usedspace) * 1024 * 1024 * 1024,
                            remainingSpace: parseFloat(connectedDevice.remainingspace) * 1024 * 1024 * 1024,
                            usedPercentage: connectedDevice.usedpercentage
                        });
                    }
                } else {
                    updateDriveStatus('DRIVE_NOT_CONNECTED');
                    updateTransferStatus({
                        return_event: 'DRIVE_NOT_CONNECTED',
                        msg: `Configured drive ${configuredDrive}: not connected`
                    });
                }
            } else {
                // No drive configured yet
                updateDriveStatus('TRANSFER_STOPPED');
                updateTransferStatus({
                    return_event: 'TRANSFER_STOPPED',
                    msg: 'No USB drive configured'
                });
            }
        }

        function loadConnectedDevices() {
            fetch(`${AUTO_TRANSFER_SERVICE_URL}/devices`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        updateConnectedDrives(data.devices);
                        devicesLoaded = true;
                        evaluateDriveStatus();
                    } else {
                        console.error('Failed to load devices:', data.error);
                        updateConnectedDrives([]);
                        devicesLoaded = true;
                        evaluateDriveStatus();
                    }
                })
                .catch(error => {
                    console.error('Error loading devices:', error);
                    updateConnectedDrives([]);
                    devicesLoaded = true;
                    evaluateDriveStatus();
                });
        }

