        function connectWebsocket() {
            socket = new WebSocket(AUTO_TRANSFER_WS_URL);

            socket.addEventListener('open', (event) => {
                console.log('WebSocket connection opened:', event);
                socket.send(JSON.stringify({action: 'subscribe', event: 'realtimeDashboard'}));
                socket.send(JSON.stringify({action: 'subscribe', event: 'devices'}));
                socket.send(JSON.stringify({action: 'subscribe', event: 'transferMetrics'}));
            });

            socket.addEventListener('message', (event) => {
                let data = JSON.parse(event.data);
                
                if (data.event === "handleAutoTransfer") {
                    const response = JSON.parse(data.data.response);
                    console.log('Auto transfer response:', response);

                    if (response.result) {
                        updateTransferStatus(response.result);
                        updateDriveStatus(response.result.return_event);
                        
                        if (response.result.data && response.result.data.driveInfo) {
                            updateDriveInfo(response.result.data.driveInfo);
                        }
                    }

                    if (data.data.error) {
                        showToast(data.data.error, 'error');
                    }
                } else if (data.event === "devices") {
                    console.log('Connected devices updated:', data.devices);
                    updateConnectedDrives(data.devices);
                    evaluateDriveStatus();
                } else if (data.event === "autoTransferConfigChanged") {
                    // Real-time cursor state update pushed by the backend
                    const cfg = data.data || data;
                    updateCursorDisplay(cfg);
                } else if (data.event === "imageTransferMetrics") {
                    console.log('Image transfer metrics:', data);
                    updateImageTransferMetrics(data);
                } else if (data.event === "videoTransferMetrics") {
                    console.log('Video transfer metrics:', data);
                    updateVideoTransferMetrics(data);
                } else if (data.event === "transferProgress") {
                    console.log('Transfer progress:', data);
                    updateTransferProgress(data);
                }
            });

            socket.addEventListener('close', (event) => {
                console.log('WebSocket connection closed:', event);
                setTimeout(connectWebsocket, 5000);
            });

            socket.addEventListener('error', (error) => {
                console.error('WebSocket error:', error);
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            
            // Load connected devices on page load
            loadConnectedDevices();
            
            // Refresh drives button handler
            document.getElementById('refreshDrives').addEventListener('click', function() {
                const button = this;
                const icon = button.querySelector('i');
                
                // Add spinning animation
                icon.classList.add('fa-spin');
                button.disabled = true;
                
                loadConnectedDevices();
                
                // Remove spinning animation after a short delay
                setTimeout(() => {
                    icon.classList.remove('fa-spin');
                    button.disabled = false;
                }, 1000);
            });
            
            // Transfer mode change handler
            $('input[name="transferMode"]').on('change', function() {
                const isSpecificMode = $(this).val() === 'specific';
                $('#driveSelectionSection').toggle(isSpecificMode);
                
                if (!isSpecificMode) {
                    // Clear drive selection when switching to "any USB" mode
                    $('#driveSelect').val('');
                }
                
                // Update drive status when transfer mode changes
                if (savedConfig) {
                    savedConfig.transferMode = $(this).val();
                    evaluateDriveStatus();
                }
            });

            // Transfer schedule change handler
            $('input[name="transferSchedule"]').on('change', function() {
                const isScheduled = $(this).val() === 'scheduled';
                $('#scheduleOptionsSection').toggle(isScheduled);
            });

            // Schedule type change handler
            $('input[name="scheduleType"]').on('change', function() {
                const scheduleType = $(this).val();
                $('#hourlyOptions').toggle(scheduleType === 'hourly');
                $('#weeklyOptions').toggle(scheduleType === 'weekly');
            });
            
            // Enable save button when any form input changes
            $('#autoTransferForm input, #autoTransferForm select').on('change', function() {
                const saveButton = document.getElementById('saveConfig');
                
                // Only enable if drive is tested or we're in 'any USB' mode
                const transferMode = $('input[name="transferMode"]:checked').val();
                if (transferMode === 'any' || isSaveConfigDriveTested) {
                    saveButton.disabled = false;
                }
            });
            
            function applyConfiguration(config) {
                console.log('DEBUG: applyConfiguration called with:', config);
                if (!config) {
                    console.log('DEBUG: No config provided to applyConfiguration');
                    return;
                }
                
                savedConfig = config; // Store config for later use
                
                // Set transfer mode and drive
                if (config.transferMode === 'any' || config.drive === 'ANY') {
                    document.getElementById('anyUSB').checked = true;
                    $('#driveSelectionSection').hide();
                } else {
                    document.getElementById('specificUSB').checked = true;
                    $('#driveSelectionSection').show();
                    // Set drive selection if drives are already loaded, otherwise it will be set in updateConnectedDrives
                    const driveSelect = document.getElementById('driveSelect');
                    if (driveSelect.options.length > 1 && config.drive) { // More than just the default option
                        driveSelect.value = config.drive;
                    }
                }
                
                // Set data type selection
                const dataType = config.dataType || 'both';
                if (dataType === 'images') {
                    document.getElementById('imagesOnly').checked = true;
                } else if (dataType === 'videos') {
                    document.getElementById('videosOnly').checked = true;
                } else {
                    document.getElementById('bothTypes').checked = true;
                }
                
                // Set encryption settings
                const useEncryption = (config.encryption && config.encryption.enabled) || false;
                document.getElementById(useEncryption ? 'useEncryption' : 'noEncryption').checked = true;
                
                // Set transfer schedule settings
                const scheduleType = (config.schedule && config.schedule.type) || 'continuous';
                document.getElementById(scheduleType === 'continuous' ? 'continuousTransfer' : 'scheduledTransfer').checked = true;
                $('#scheduleOptionsSection').toggle(scheduleType !== 'continuous');
                
                if (scheduleType !== 'continuous' && config.schedule) {
                    const scheduleMode = config.schedule.mode || 'hourly';
                    document.getElementById(scheduleMode === 'hourly' ? 'hourlySchedule' : 'weeklySchedule').checked = true;
                    $('#hourlyOptions').toggle(scheduleMode === 'hourly');
                    $('#weeklyOptions').toggle(scheduleMode === 'weekly');
                    
                    if (scheduleMode === 'hourly' && config.schedule.hour !== undefined) {
                        document.getElementById('scheduleHour').value = config.schedule.hour;
                    }
                    
                    if (scheduleMode === 'weekly') {
                        if (config.schedule.dayOfWeek !== undefined) {
                            document.getElementById('scheduleDayOfWeek').value = config.schedule.dayOfWeek;
                        }
                        if (config.schedule.hour !== undefined) {
                            document.getElementById('scheduleWeeklyHour').value = config.schedule.hour;
                        }
                    }
                }
                
                // Set transfer active status and toggle form
                const isActive = config.isActive || false;
                document.getElementById('transferActiveToggle').checked = isActive;
                toggleFormControls(isActive);

                // Update cursor state display (new time-cursor fields)
                updateCursorDisplay(config);
            }

            // Load initial configuration
            console.log('DEBUG: Loading configuration from:', `${AUTO_TRANSFER_SERVICE_URL}/auto-transfer/config`);
            fetch(`${AUTO_TRANSFER_SERVICE_URL}/auto-transfer/config`)
                .then(response => {
                    console.log('DEBUG: Config response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('DEBUG: Config response data:', data);
                    if (data.success && data.config) {
                        console.log('DEBUG: Applying configuration:', data.config);
                        applyConfiguration(data.config);
                    } else {
                        console.log('DEBUG: No valid config found in response');
                    }
                    configLoaded = true;
                    evaluateDriveStatus();
                })
                .catch(error => {
                    console.error('Error loading config:', error);
                    showToast('Failed to load configuration', 'error');
                    configLoaded = true;
                    evaluateDriveStatus();
                });

            
            // Test drive connection
            document.getElementById('testConnection').addEventListener('click', async function() {
                const transferMode = $('input[name="transferMode"]:checked').val();
                
                if (transferMode === 'any') {
                    if (connectedDevices.length === 0) {
                        showToast('No USB drives are currently connected. Please connect a USB drive first.', 'warning');
                    } else {
                        showToast(`Test connection: Found ${connectedDevices.length} connected USB drive(s). System will automatically use any connected drive for transfers.`, 'success');
                        updateDriveStatus('CONNECTED');
                    }
                    return;
                }
                
                const drive = document.getElementById('driveSelect').value;
                if (!drive) {
                    if (connectedDevices.length === 0) {
                        showToast('No USB drives are connected. Please connect a USB drive first.', 'warning');
                    } else {
                        showToast('Please select a drive from the list', 'error');
                    }
                    return;
                }

                try {
                    const response = await fetch(`${AUTO_TRANSFER_SERVICE_URL}/auto-transfer/test-drive`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ drive })
                    });

                    const data = await response.json();
                    
                    if (data.success) {
                        showToast(data.message, 'success');
                        if (data.driveInfo) {
                            updateDriveInfo(data.driveInfo);
                            updateDriveStatus('CONNECTED');
                        }
                    } else {
                        showToast(data.error, 'error');
                        updateDriveStatus('DRIVE_NOT_CONNECTED');
                    }
                } catch (error) {
                    console.error('Error testing drive:', error);
                    showToast('Failed to test drive connection', 'error');
                    updateDriveStatus('DRIVE_NOT_CONNECTED');
                }
            });

            // Save configuration
            document.getElementById('saveConfig').addEventListener('click', async function() {
                // Check if drive is connected before saving
                console.log(isDriveConnected, isSaveConfigDriveTested);
                /*
                if (!isDriveConnected || !isSaveConfigDriveTested) {
                    showToast('Please test drive connection first', 'error');
                    return;
                }
                */

                const transferMode = $('input[name="transferMode"]:checked').val();
                const dataType = $('input[name="dataType"]:checked').val();
                const scheduleType = $('input[name="transferSchedule"]:checked').val();
                
                const config = {
                    transferMode: transferMode,
                    drive: transferMode === 'any' ? 'ANY' : document.getElementById('driveSelect').value,
                    dataType: dataType,
                    encryption: {
                        enabled: document.getElementById('useEncryption').checked
                    },
                    schedule: {
                        type: scheduleType
                    },
                    isActive: document.getElementById('transferActiveToggle').checked
                };

                // Add schedule configuration if scheduled transfer is selected
                if (scheduleType === 'scheduled') {
                    const scheduleMode = $('input[name="scheduleType"]:checked').val();
                    config.schedule.mode = scheduleMode;
                    
                    if (scheduleMode === 'hourly') {
                        config.schedule.hour = parseInt(document.getElementById('scheduleHour').value);
                    } else if (scheduleMode === 'weekly') {
                        config.schedule.dayOfWeek = parseInt(document.getElementById('scheduleDayOfWeek').value);
                        config.schedule.hour = parseInt(document.getElementById('scheduleWeeklyHour').value);
                    }
                }

                try {
                    const response = await fetch(`${AUTO_TRANSFER_SERVICE_URL}/auto-transfer/save-config`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(config)
                    });

                    const data = await response.json();
                    
                    if (data.success) {
                        showToast('Configuration saved successfully', 'success');
                        // Update saved config and apply it to maintain consistency
                        savedConfig = config;
                        applyConfiguration(config);
                        evaluateDriveStatus(); // Update drive status immediately after saving
                    } else {
                        showToast(data.error || 'Failed to save configuration', 'error');
                    }
                } catch (error) {
                    console.error('Error saving config:', error);
                    showToast('Failed to save configuration', 'error');
                }
            });

            // Toggle transfer status
            const transferToggle = document.getElementById('transferActiveToggle');
            transferToggle.addEventListener('change', async function() {
                const isActive = this.checked;
                
                // Get current schedule configuration when toggling
                const scheduleType = $('input[name="transferSchedule"]:checked').val();
                const toggleData = { isActive };
                
                if (scheduleType === 'scheduled') {
                    const scheduleMode = $('input[name="scheduleType"]:checked').val();
                    toggleData.schedule = {
                        type: scheduleType,
                        mode: scheduleMode
                    };
                    
                    if (scheduleMode === 'hourly') {
                        toggleData.schedule.hour = parseInt(document.getElementById('scheduleHour').value);
                    } else if (scheduleMode === 'weekly') {
                        toggleData.schedule.dayOfWeek = parseInt(document.getElementById('scheduleDayOfWeek').value);
                        toggleData.schedule.hour = parseInt(document.getElementById('scheduleWeeklyHour').value);
                    }
                } else {
                    toggleData.schedule = { type: 'continuous' };
                }
                
                try {
                    const response = await fetch(`${AUTO_TRANSFER_SERVICE_URL}/auto-transfer/toggle`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(toggleData)
                    });

                    const data = await response.json();
                    
                    if (data.success) {
                        showToast(`Auto transfer ${isActive ? 'activated' : 'deactivated'}`, 'success');
                        updateDriveStatus(isActive ? 'CONNECTED' : 'TRANSFER_STOPPED');
                        updateTransferStatus({
                            return_event: isActive ? 'COPY_SUCCESS' : 'TRANSFER_STOPPED',
                            msg: isActive ? 'Auto transfer activated' : 'Auto transfer deactivated'
                        });
                        toggleFormControls(isActive);
                    } else {
                        this.checked = !isActive;  // Revert the toggle
                        showToast(data.error || 'Failed to toggle auto transfer', 'error');
                    }
                } catch (error) {
                    console.error('Error toggling transfer:', error);
                    this.checked = !isActive;  // Revert the toggle
                    showToast('Failed to toggle auto transfer', 'error');
                }
            });

            // Initialize progress card to idle state
            resetProgressToIdle();
            
            // Connect WebSocket
            connectWebsocket();
            
            // DEBUG: Test the functions after page load
            setTimeout(() => {
                console.log('DEBUG: Testing transfer progress functions...');
                
                // Test if functions exist
                console.log('DEBUG: updateImageTransferMetrics exists:', typeof updateImageTransferMetrics);
                console.log('DEBUG: resetProgressToIdle exists:', typeof resetProgressToIdle);
                
                // Progress card is always visible and initialized to idle state
                console.log('DEBUG: Progress card is always visible and ready');
            }, 2000);
        });
    </script>
{% endblock %}