# TAHAKOM DATA TRANSFER - ENVIRONMENT CONFIG 
  
# Application Settings  
PORT=8454  
NODE_ENV=development  
  
# Directory Configuration  
ROOT_DIR=D:\ISS\SA\6_Tahakom\DataTransferPlugin\data_transfer_v2  
EXPORT_DIR=C:\export  
CONFIG_FILE_NAME=dataTransferConfig.json 
  
# Database Configuration  
DB_HOST=localhost  
DB_PORT=5432  
DB_USER=postgres  
DB_PASSWORD=postgres  
DB_NAME=tahakom_transfer  
  
# Redis Configuration  
REDIS_HOST=localhost  
REDIS_PORT=6379 
  
# Logging Configuration  
LOG_LEVEL=info  
LOG_DIRECTORY=logs  
  
# Default Encryption Settings  
DEFAULT_ENCRYPTION_ALGORITHM=aes-256-cbc  
DEFAULT_ENCRYPTION_METADATA=true  
  
# Certificate Settings  
CERTIFICATES_DIR=certs 
LOG_MAX_SIZE=20m  
LOG_MAX_FILES=14d 
  
# Additional Default Settings  
DEFAULT_ENCRYPTION_ENABLED=false  
DEFAULT_ENCRYPTION_KEY_MANAGEMENT=manual  
DEFAULT_STORAGE_DIRECTORY=C:\export  
DEFAULT_STORAGE_MAX_CAPACITY=200  
DEFAULT_STORAGE_RETENTION_POLICY=fifo  
DEFAULT_SITE_ID= 
