        <mxCell id="Clgrz6KutVEwSVbCciD1-1" value="&lt;h1&gt;Select Files in 3 Pack&lt;/h1&gt;&lt;p&gt;Select files when they are completed a pack of 3 files, once selected then they will be processed as a single point in the array, where the system will issue copy command for those files, I am sending 100 files to the copy command so the total of files to be copied are 300 files then another 300 files and so on.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;SELECT &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;ARRAY_AGG&lt;/span&gt;(&lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;id&lt;/span&gt;) &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AS&lt;/span&gt; &lt;span style=&quot;color:#006464;font-style:italic;&quot;&gt;ids&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;ARRAY_AGG&lt;/span&gt;(&lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;tid&lt;/span&gt;) &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AS&lt;/span&gt; &lt;span style=&quot;color:#006464;font-style:italic;&quot;&gt;tids&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#006464;&quot;&gt;plate_num&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#006464;&quot;&gt;site_id&lt;/span&gt;,&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#006464;&quot;&gt;date_folder&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#006464;&quot;&gt;time_folder&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;ARRAY_AGG&lt;/span&gt;(&lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;file_path&lt;/span&gt;) &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AS&lt;/span&gt; &lt;span style=&quot;color:#006464;font-style:italic;&quot;&gt;file_paths&lt;/span&gt;,&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;ARRAY_AGG&lt;/span&gt;(&lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;file_size&lt;/span&gt;) &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AS&lt;/span&gt; &lt;span style=&quot;color:#006464;font-style:italic;&quot;&gt;file_sizes&lt;/span&gt;, &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;ARRAY_AGG&lt;/span&gt;(&lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;file_name&lt;/span&gt;) &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AS&lt;/span&gt; &lt;span style=&quot;color:#006464;font-style:italic;&quot;&gt;file_names&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;FROM&lt;/span&gt; &lt;span style=&quot;color:#956037;&quot;&gt;public&lt;/span&gt;.&lt;span style=&quot;color:#8e00c6;&quot;&gt;files&lt;/span&gt; &lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;WHERE&lt;/span&gt; f.deleted = &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;false&lt;/span&gt; &lt;/p&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;GROUP&lt;/span&gt; &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;BY&lt;/span&gt; &lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;plate_num&lt;/span&gt;, &lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;site_id&lt;/span&gt;, &lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;date_folder&lt;/span&gt;, &lt;span style=&quot;color:#8e00c6;font-style:italic;&quot;&gt;f&lt;/span&gt;.&lt;span style=&quot;color:#006464;&quot;&gt;time_folder&lt;/span&gt;&lt;/p&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;HAVING&lt;/span&gt; &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;blockquote style=&quot;margin: 0 0 0 40px; border: none; padding: 0px;&quot;&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;BOOL_AND&lt;/span&gt;(f.file_size &amp;gt; &lt;span style=&quot;color:#0000ff;&quot;&gt;0&lt;/span&gt;) &lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;AND&lt;/span&gt; &lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;BOOL_OR&lt;/span&gt;(&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;NOT&lt;/span&gt; &lt;span style=&quot;color:#000080;font-weight:bold;&quot;&gt;COALESCE&lt;/span&gt;(f.is_auto_transferred, &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;false&lt;/span&gt;))&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/blockquote&gt;&lt;div style=&quot;padding: 0px 2px;&quot;&gt;&lt;div style=&quot;font-family: &amp;quot;Courier New&amp;quot;; font-size: 10pt;&quot;&gt;&lt;p style=&quot;margin:0;&quot;&gt;&lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;ORDER&lt;/span&gt; &lt;span style=&quot;color:#800000;font-weight:bold;&quot;&gt;BY&lt;/span&gt;&amp