{
  "title": "Frontend Script Guide",
  "version": "1.0.0",
  "description": "Comprehensive guide to JavaScript implementation patterns and scripts in the Tahakom Data Transfer System frontend",
  
  "javascript_architecture": {
    "overview": "Client-side JavaScript architecture built on modern ES6+ patterns with jQuery integration",
    "core_technologies": [
      "Vanilla JavaScript (ES6+)",
      "jQuery 3.x",
      "Bootstrap 5.x JavaScript components",
      "Apache ECharts 5.4.3",
      "WebSocket API",
      "Fetch API"
    ],
    "design_patterns": [
      "Module pattern for script organization",
      "Event-driven architecture",
      "Real-time data synchronization via WebSocket",
      "Reactive UI updates",
      "Error-first callback pattern"
    ]
  },

  "common_patterns": {
    "api_communication": {
      "base_urls": {
        "main_service": "http://localhost:8454",
        "websocket": "ws://localhost:8454"
      },
      "http_requests": {
        "pattern": "Fetch API with async/await",
        "example": {
          "get_request": "fetch(`${SERVICE_URL}/endpoint`).then(response => response.json())",
          "post_request": "fetch(`${SERVICE_URL}/endpoint`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) })",
          "error_handling": "try/catch blocks with user-friendly error messages"
        },
        "response_format": {
          "success": "{ success: true, data: {...}, message?: 'optional' }",
          "error": "{ success: false, error: 'error message', details?: {...} }"
        }
      },
      "websocket_communication": {
        "connection_pattern": "Auto-reconnecting WebSocket with exponential backoff",
        "subscription_format": "{ action: 'subscribe', event: 'event_name' }",
        "message_handling": "JSON.parse with error handling and event routing",
        "common_events": [
          "realtimeDashboard",
          "realtimeVideoDashboard", 
          "devices",
          "processes",
          "handleAutoTransfer",
          "handleAutoVideoTransfer",
          "manualTransferConfig"
        ]
      }
    },

    "ui_patterns": {
      "toast_notifications": {
        "implementation": "Bootstrap 5 Toast component",
        "function_signature": "showToast(message, type = 'info')",
        "types": ["info", "success", "error", "warning"],
        "pattern": "Global toast container with automatic positioning and dismissal"
      },
      "form_handling": {
        "validation": "HTML5 validation with custom JavaScript checks",
        "submission": "preventDefault() with async form processing",
        "data_collection": "FormData or manual object construction",
        "state_management": "Form disable/enable during processing"
      },
      "modal_management": {
        "library": "Bootstrap 5 Modal component",
        "initialization": "new bootstrap.Modal(element)",
        "data_population": "Dynamic content loading on show.bs.modal event",
        "cleanup": "Event listener cleanup on modal hide"
      },
      "progress_indicators": {
        "types": ["Bootstrap progress bars", "Custom loading states", "Real-time progress updates"],
        "update_pattern": "Percentage-based width updates with color coding"
      }
    },

    "utility_functions": {
      "data_formatting": {
        "formatBytes": "Convert bytes to human-readable format (Bytes, KB, MB, GB, TB)",
        "formatNumber": "Number formatting with locale-specific separators",
        "formatDateTime": "ISO string to localized date/time format",
        "formatDuration": "Minutes to hours/minutes format"
      },
      "dom_manipulation": {
        "element_creation": "Template string literals with dynamic content",
        "class_management": "classList.add/remove for state changes",
        "content_updates": "innerHTML and textContent for data binding"
      }
    }
  },

  "page_implementations": {
    "auto_transfer_page": {
      "file": "data_transfer_v2/views/auto_transfer.njk",
      "description": "Automatic USB transfer configuration and monitoring",
      "key_features": [
        "Drive configuration and testing",
        "Encryption settings management",
        "Real-time transfer status",
        "Drive capacity monitoring"
      ],
      "javascript_components": {
        "configuration_management": {
          "load_config": "GET /auto-transfer/config on page load",
          "save_config": "POST /auto-transfer/save-config with form data",
          "test_drive": "POST /auto-transfer/test-drive with drive validation",
          "toggle_transfer": "POST /auto-transfer/toggle for activation state"
        },
        "websocket_integration": {
          "subscription": "realtimeDashboard event subscription",
          "event_handling": "handleAutoTransfer event for status updates",
          "ui_updates": [
            "updateTransferStatus() for transfer state",
            "updateDriveStatus() for connection state", 
            "updateDriveInfo() for capacity information"
          ]
        },
        "form_controls": {
          "encryption_toggle": "Radio button handling for encryption options",
          "drive_selection": "Dropdown with validation",
          "form_state": "toggleFormControls() for active/inactive states"
        },
        "status_indicators": {
          "drive_status": "Visual status with icons and badges",
          "transfer_progress": "Real-time progress with status messages",
          "capacity_display": "Progress bars and formatted size display"
        }
      }
    },

    "auto_transfer_video_page": {
      "file": "data_transfer_v2/views/auto_transfer_video.njk", 
      "description": "Automatic video transfer configuration (similar to auto_transfer)",
      "differences": {
        "websocket_event": "realtimeVideoDashboard instead of realtimeDashboard",
        "api_endpoints": "/auto-transfer-video/* instead of /auto-transfer/*",
        "event_handling": "handleAutoVideoTransfer instead of handleAutoTransfer"
      },
      "implementation": "Nearly identical to auto_transfer.njk with different API endpoints"
    },

    "dashboard_page": {
      "file": "data_transfer_v2/views/dashboard.njk",
      "description": "Statistical dashboard with charts and data visualization",
      "key_features": [
        "Multi-view data display (hourly/daily/monthly/yearly)",
        "Interactive charts with Apache ECharts",
        "Dynamic filtering and export functionality",
        "Real-time data refresh"
      ],
      "javascript_components": {
        "chart_management": {
          "library": "Apache ECharts 5.4.3",
          "initialization": "echarts.init(document.getElementById('chartId'))",
          "chart_types": [
            "Line charts for trends",
            "Bar charts for comparisons", 
            "Pie charts for distributions",
            "Area charts for cumulative data"
          ],
          "update_functions": [
            "updateMainChart(data)",
            "updateSuccessChart(data)",
            "updateFileSizeChart(data)", 
            "updateVehicleChart(data)"
          ],
          "responsive_design": "window.addEventListener('resize') with chart.resize()"
        },
        "filter_system": {
          "dynamic_filters": "renderFilters() based on current view",
          "filter_types": [
            "Date range pickers",
            "Time selectors",
            "Camera dropdowns",
            "Vehicle type filters"
          ],
          "filter_application": "getFilterParams() with URLSearchParams construction"
        },
        "data_management": {
          "api_calls": [
            "GET /dashboard/data with query parameters",
            "GET /dashboard/cameras for filter options",
            "GET /dashboard/vehicle-types for filter options"
          ],
          "data_processing": [
            "updateStatistics(data) for metric cards",
            "updateDataTable(data) for tabular display"
          ]
        },
        "export_functionality": {
          "formats": ["PDF", "JSON", "XML", "Operation Reports"],
          "implementation": "window.open(url, '_blank') for file downloads"
        }
      }
    },

    "devices_page": {
      "file": "data_transfer_v2/views/devices.njk",
