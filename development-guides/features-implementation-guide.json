{
  "title": "Features Implementation Guide",
  "version": "1.0.0",
  "description": "Comprehensive guide to feature implementation in the Tahakom Data Transfer System",
  
  "features_overview": {
    "core_features": [
      "Automatic File Transfer",
      "Manual File Transfer", 
      "Dashboard & Reporting",
      "Device Management",
      "Process Monitoring",
      "File Management",
      "Configuration Management",
      "Real-time Updates"
    ],
    "architecture_pattern": "Microservices with shared state via Redis",
    "communication": "REST APIs + WebSocket for real-time updates"
  },

  "automatic_transfer_feature": {
    "description": "Automatically transfer files to connected USB drives when configured conditions are met",
    
    "backend_implementation": {
      "main_service": "FileTransferRedisService.js",
      "api_routes": "routes/autoTransferRoutes.js", 
      "configuration": "ConfigStateServiceRedis.js",
      "drive_monitoring": "DriveStateServiceRedis.js",
      
      "workflow": {
        "1": "Monitor drive connection status via DriveStateServiceRedis",
        "2": "Check auto-transfer configuration via ConfigStateServiceRedis",
        "3": "Query database for files to transfer via startAutoTransferProcess()",
        "4": "Queue files for transfer via Redis queue system",
        "5": "Process queue in FileTransferRedisService",
        "6": "Send status updates via WebSocket"
      },
      
      "database_queries": {
        "get_files_to_transfer": "SELECT files grouped by plate_num, site_id, date_folder, time_folder WHERE not auto_transferred",
        "update_transfer_status": "UPDATE files SET is_auto_transferred = true WHERE id IN (...)"
      },
      
      "redis_patterns": {
        "queues": ["image_file_transfer_queue", "image_file_transfer_result_queue"],
        "state_keys": ["CONNECTED_DRIVE_STATE", "CONFIG_STATE_KEY"],
        "pubsub": ["CONNECTED_DRIVE_STATE_update", "CONFIG_STATE_KEY_update"]
      }
    },
    
    "frontend_implementation": {
      "page": "data_transfer_v2/views/auto_transfer.njk",
      "api_endpoints": [
        "GET /auto-transfer/config",
        "POST /auto-transfer/test-drive",
        "POST /auto-transfer/save-config", 
        "POST /auto-transfer/toggle"
      ],
      "websocket_events": ["handleAutoTransfer"],
      "ui_components": [
        "Drive selection dropdown",
        "Encryption configuration",
        "Transfer status display",
        "Real-time progress updates"
      ]
    },
    
    "configuration_options": {
      "drive_selection": "Target drive letter (E:, F:, etc.)",
      "encryption": {
        "enabled": "boolean",
        "algorithm": "aes-256|aes-128|chacha20",
        "keyManagement": "manual|certificate|kms",
        "encryptMetadata": "boolean"
      },
      "transfer_control": {
        "isActive": "boolean",
        "stopPercentage": "number (95% default)"
      }
    }
  },

  "manual_transfer_feature": {
    "description": "User-initiated file transfer with date/time range selection",
    
    "backend_implementation": {
      "api_routes": "routes/manualTransferRoutes.js",
      "background_service": "startManualFileTransferProcess() in manualTransferRoutes.js",
      "job_management": "transfer_job and transfer_job_log tables",
      
      "workflow": {
        "1": "User creates transfer job with date range and USB path",
        "2": "System queries files in date range and creates job record",
        "3": "Background process monitors job status via config",
        "4": "Files copied in batches with progress tracking",
        "5": "Job status updated in database and config",
        "6": "Real-time updates sent via WebSocket"
      },
      
      "database_operations": {
        "create_job": "INSERT INTO transfer_job (start_date, end_date, usb_path, status)",
        "create_file_records": "INSERT INTO transfer_job_log (file_id, transfer_job_id, transferred)",
        "update_progress": "UPDATE transfer_job_log SET transferred = true WHERE id = ?",
        "job_control": "UPDATE transfer_job SET status = ? WHERE id = ?"
      }
    },
    
    "frontend_implementation": {
      "page": "data_transfer_v2/views/manual_usb.njk",
      "api_endpoints": [
        "GET /manual-transfer/drives",
        "POST /manual-transfer/create",
        "POST /manual-transfer/control",
        "GET /manual-transfer/history"
      ],
      "features": [
        "Date/time range picker",
        "USB drive selection",
        "Transfer progress tracking",
        "Job control (pause/resume/cancel)",
        "Transfer history"
      ]
    }
  },

  "dashboard_reporting_feature": {
    "description": "Statistical dashboard with charts and data export capabilities",
    
    "backend_implementation": {
      "api_routes": "routes/dashboardRoutes.js",
      "data_aggregation": "SQL queries with GROUP BY and time-based filtering",
      "export_formats": ["JSON", "XML", "PDF"],
      
      "sql_queries": {
        "hourly_view": "GROUP BY TO_CHAR(time, 'HH12 AM'), date",
        "daily_view": "GROUP BY date",
        "monthly_view": "GROUP BY TO_CHAR(date, 'YYYY-MM')",
        "yearly_view": "GROUP BY TO_CHAR(date, 'YYYY')"
      },
      
      "metrics_calculated": [
        "total_vehicles_count",
        "total_files_count", 
        "success_produced_count",
        "failed_produce_count",
        "failed_produced_percentage",
        "total_file_size_in_gb"
      ]
    },
    
    "frontend_implementation": {
      "page": "data_transfer_v2/views/dashboard.njk",
      "chart_library": "Apache ECharts",
      "chart_types": ["Line", "Bar", "Pie", "Area"],
      "filters": [
        "Date range selection",
        "Camera filter",
        "Vehicle type filter",
        "Time period view (hourly/daily/monthly/yearly)"
      ],
      "export_options": [
        "PDF reports",
        "JSON data export",
        "XML data export",
        "Daily operation reports"
      ]
    }
  },

  "device_management_feature": {
    "description": "Monitor and manage connected external storage devices",
    
    "backend_implementation": {
      "monitoring_service": "monitorConnectedExternalDrivesMicroservice.js",
      "api_routes": "routes/connectedDevicesRoutes.js",
      "database_tracking": "device_connections table",
      
      "monitoring_workflow": {
        "1": "Periodic scan of connected drives using systeminformation",
        "2": "Detect new connections and disconnections",
        "3": "Store connection events in database",
        "4": "Update Redis state with current drive information",
        "5": "Publish updates via Redis pub/sub",
        "6": "Send WebSocket updates to connected clients"
      },
      
      "drive_information_collected": [
        "Drive letter",
        "Label/name",
        "Total space",
        "Used space",
        "Remaining space",
        "File system type",
        "Read/write status",
        "Connection timestamp"
      ]
    },
    
    "frontend_implementation": {
      "page": "data_transfer_v2/views/devices.njk",
      "real_time_updates": "WebSocket connection for live device status",
      "ui_components": [
        "Device cards with space usage",
        "Connection history table",
        "Refresh controls",
        "Device status indicators"
      ]
    }
  },

